# Trading Stack — Environment Variables
# Copy this file to .env and fill in your values before running docker compose.
# .env is never committed; only .env.example is tracked in git.

# ─── IBKR Credentials ────────────────────────────────────────────────────────
# Your Interactive Brokers username (TWS login)
TWS_USERID=your_ibkr_username

# Your Interactive Brokers password (TWS login)
TWS_PASSWORD=your_ibkr_password

# Trading mode: "paper" uses IBKR paper-trading account (safe default).
# Switch to "live" only after paper-trading validation.
# Changes the API port TWS listens on (paper: 7497, live: 7496).
TRADING_MODE=paper

# ─── API Port ─────────────────────────────────────────────────────────────────
# TWS API socket port the data-collector and strategy-runner connect to.
# Default 7497 = TWS paper trading. Change to 7496 for TRADING_MODE=live.
# (IB Gateway uses different ports: 4002 paper / 4002 live — not used here.)
TWS_API_PORT=7497

# Client IDs must be unique per simultaneous ib_insync connection.
COLLECTOR_CLIENT_ID=1
# Strategy runner processes use client IDs 10+ (configured in strategies.yml)

# ─── TimescaleDB ──────────────────────────────────────────────────────────────
# Secure password for the trading PostgreSQL database.
# Generate one with: openssl rand -base64 24
TRADING_DB_PASSWORD=change_me_generate_with_openssl

# Database name and username (defaults are fine; change only if you have a reason to)
TRADING_DB_USER=trading
TRADING_DB_NAME=trading

# ─── Domain ───────────────────────────────────────────────────────────────────
# Base domain used by Traefik to route tws.${DOMAIN} to KasmVNC.
# This is the same DOMAIN as in the root server/.env; set it here too so
# docker compose can resolve it without sourcing the root .env.
DOMAIN=example.com

# ─── Timezone ─────────────────────────────────────────────────────────────────
# Used by TWS container and cron scripts.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# ─── Data Paths ───────────────────────────────────────────────────────────────
# Root directory for all trading persistent data on the block volume.
# Sub-directories created by install.sh: timescaledb/, tws-settings/, parquet/
TRADING_DATA_PATH=/data/trading

# ─── Backblaze B2 ─────────────────────────────────────────────────────────────
# B2 credentials for Parquet archive sync.
# These are the same as in the root server/.env — set them here too for the
# standalone trading scripts in server/scripts/trading/.
B2_BUCKET_NAME=your-bucket-name
B2_APPLICATION_KEY_ID=your_b2_key_id
B2_APPLICATION_KEY=your_b2_application_key
# Path prefix inside the bucket where trading backups live
B2_BACKUPS_PATH=backups
