# Domain used for public routes
DOMAIN=example.com

# code-server password (used by the browser login page)
CODE_SERVER_PASSWORD=change-me

# Persistent storage paths
DEVTOOLS_PROJECTS_PATH=/data/devtools/projects
CODE_SERVER_BASE_PATH=/data/devtools/code-server
FILEBROWSER_DATA_PATH=/data/devtools/filebrowser
OLLAMA_DATA_PATH=/data/devtools/ollama

# FileBrowser permissions
DEVTOOLS_PUID=1000
DEVTOOLS_PGID=1000

# Ollama runtime
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_NUM_PARALLEL=4
OLLAMA_KEEP_ALIVE=-1
