# Self-Hosted Infrastructure Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ==========================================
# DOMAIN CONFIGURATION
# ==========================================
# Your domain name (required for SSL certificates)
DOMAIN=example.com

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# Traefik Dashboard Password (generate with: htpasswd -nb admin yourpassword)
TRAEFIK_PASSWORD='$apr1$H6uskkkW$IgXLP6ewTrSuBkTrqE8wj/'

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_to_a_secure_password

# ==========================================
# GRAFANA CONFIGURATION
# ==========================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_to_a_secure_password

# ==========================================
# BACKBLAZE B2 CONFIGURATION
# ==========================================
# Create these in your Backblaze B2 console under App Keys
B2_APPLICATION_KEY_ID=your_key_id_here
B2_APPLICATION_KEY=your_application_key_here

# B2 Bucket Names (optional - defaults shown)
B2_PHOTOS_BUCKET=immich-photos
B2_BACKUP_BUCKET=backups
B2_BACKUP_PATH=homelab

# ==========================================
# SERVICE-SPECIFIC CONFIGURATION
# ==========================================
# Immich
IMMICH_VERSION=release

# Nextcloud (Phase 3)
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_this_to_a_secure_password

# Vaultwarden (Phase 4)
VAULTWARDEN_ADMIN_TOKEN=change_this_to_a_secure_random_token
