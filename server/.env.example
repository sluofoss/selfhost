# Global Configuration (used by backup scripts and shared across services)
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ==========================================
# DOMAIN CONFIGURATION
# ==========================================
# Your domain name (used by multiple services)
DOMAIN=example.com

# ==========================================
# BACKBLAZE B2 CONFIGURATION
# ==========================================
# Create these in your Backblaze B2 console under App Keys
B2_APPLICATION_KEY_ID=your_key_id_here
B2_APPLICATION_KEY=your_application_key_here

# Single B2 bucket for everything (photos, backups, terraform state)
B2_BUCKET_NAME=sluo-personal-b2

# Paths within the bucket (for organization)
B2_PHOTOS_PATH=photos
B2_BACKUPS_PATH=backups
B2_TERRAFORM_PATH=terraform

# ==========================================
# SERVICE-SPECIFIC CONFIGURATION
# Each service has its own .env file in its directory:
#   - traefik/.env      (ACME_EMAIL, TRAEFIK_PASSWORD)
#   - immich/.env       (DB_PASSWORD, UPLOAD_LOCATION, etc)
#   - monitoring/.env   (GRAFANA_USER, GRAFANA_PASSWORD)
# ==========================================