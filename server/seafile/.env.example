# Seafile Pro configuration
# Copy this file to .env and fill in all values before first start.
# DO NOT commit .env to git.

# ── Hostname ────────────────────────────────────────────────────────────────
# DNS A record must point to this server.
SEAFILE_HOSTNAME=seafile.example.com

# ── MariaDB ─────────────────────────────────────────────────────────────────
# Both values must match. Only used to initialize the database on first start.
INIT_SEAFILE_MYSQL_ROOT_PASSWORD=change_this_root_password
# Password for the seafile MariaDB user (used on every start).
SEAFILE_MYSQL_DB_PASSWORD=change_this_db_password

# ── Redis ────────────────────────────────────────────────────────────────────
SEAFILE_REDIS_PASSWORD=change_this_redis_password

# ── JWT signing key ───────────────────────────────────────────────────────────
# Generate with: pwgen -s 40 1
JWT_PRIVATE_KEY=change_this_to_40_char_random_string

# ── Initial admin account (used only on first start) ─────────────────────────
INIT_SEAFILE_ADMIN_EMAIL=admin@example.com
INIT_SEAFILE_ADMIN_PASSWORD=change_this_admin_password

# ── Time zone ─────────────────────────────────────────────────────────────────
TIME_ZONE=Australia/Sydney

# ── Data paths ────────────────────────────────────────────────────────────────
SEAFILE_DATA=/data/seafile/share
SEAFILE_MYSQL_DATA=/data/seafile/mysql

# ── B2 / S3 storage backend ───────────────────────────────────────────────────
# Requires a dedicated B2 application key that is NOT bucket-restricted.
# The key must have read/write access to all three Seafile buckets listed below.
# Steps to create:
#   1. In B2 console, create 3 Private buckets:
#        sluo-seafile-commits, sluo-seafile-fs, sluo-seafile-blocks
#   2. Create a new App Key (not restricted to any bucket) with capabilities:
#        listBuckets, readBuckets, listFiles, readFiles, writeFiles, deleteFiles
#   3. Paste key ID and key below.
SEAF_SERVER_STORAGE_TYPE=s3
S3_KEY_ID=your_seafile_b2_key_id
S3_SECRET_KEY=your_seafile_b2_key
S3_HOST=s3.us-east-005.backblazeb2.com
S3_AWS_REGION=us-east-005
S3_PATH_STYLE_REQUEST=true
S3_USE_V4_SIGNATURE=true
S3_USE_HTTPS=true
S3_COMMIT_BUCKET=sluo-seafile-commits
S3_FS_BUCKET=sluo-seafile-fs
S3_BLOCK_BUCKET=sluo-seafile-blocks
