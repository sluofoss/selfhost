# Traefik Configuration
# Copy this file to .env and fill in your values

# Your domain name (used for SSL certificates)
DOMAIN=example.com

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# Traefik Dashboard Password (generate with: htpasswd -nb admin yourpassword)
# This is the hashed password, not plaintext
TRAEFIK_PASSWORD='$apr1$H6uskkkW$IgXLP6ewTrSuBkTrqE8wj/'