# Traefik Configuration
# Copy this file to .env and fill in your values

# Your domain name (used for SSL certificates)
DOMAIN=example.com

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# Cloudflare API token for DNS-01 certificate challenge (automatic HTTPS)
# Create at: Cloudflare Dashboard → My Profile → API Tokens → Create Token
# Required permissions: Zone / DNS / Edit — scoped to your zone only
# This token lets Traefik create temporary DNS TXT records to prove
# domain ownership to Let's Encrypt. It is never exposed publicly.
CF_DNS_API_TOKEN=your_cloudflare_api_token_here

# Traefik Dashboard Password (generate with: htpasswd -nb admin yourpassword)
# This is the hashed password, not plaintext
TRAEFIK_PASSWORD='$apr1$H6uskkkW$IgXLP6ewTrSuBkTrqE8wj/'