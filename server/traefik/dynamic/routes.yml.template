http:
  routers:
    # api@internal is Traefik's built-in service — not a container, cannot use
    # Docker labels. This is the only route that must live in the file provider.
    traefik:
      rule: "Host(`traefik.${DOMAIN}`)"
      service: api@internal
      entrypoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - authelia@file
