# Authelia configuration
# Copy to .env and fill in values

# Base domain (used in Traefik router rule)
DOMAIN=example.com

# Authelia secrets — generate each with: openssl rand -hex 64
# All three must be unique and at least 20 characters.
# JWT_SECRET is deliberately NOT prefixed with AUTHELIA_ to avoid Authelia's legacy
# auto-mapping; docker-compose.yml maps it to AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET
JWT_SECRET=replace_with_openssl_rand_hex_64_output
AUTHELIA_SESSION_SECRET=replace_with_openssl_rand_hex_64_output
AUTHELIA_STORAGE_ENCRYPTION_KEY=replace_with_openssl_rand_hex_64_output
